# ══════════════════════════════════════════════
# Copy this file to .env and fill in values
# NEVER commit .env to git!
# ══════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB — for Docker Compose:
MONGO_URI=mongodb://admin:changeme@mongodb:27017/bankingdb?authSource=admin

# MongoDB — for local dev (no Docker):
# MONGO_URI=mongodb://localhost:27017/bankingdb

# JWT — MUST be a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-please-change-this-in-production-use-crypto-randomBytes
JWT_EXPIRES=24h

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
