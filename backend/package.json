{
  "name": "banking-backend",
  "version": "2.0.0",
  "description": "NovaBanc three-tier banking backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev":   "nodemon src/server.js",
    "test":  "jest --coverage --forceExit"
  },
  "dependencies": {
    "bcryptjs":         "^2.4.3",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "express":          "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "mongoose":         "^8.4.1",
    "morgan":           "^1.10.0",
    "prom-client":      "^15.1.3"
  },
  "devDependencies": {
    "jest":    "^29.7.0",
    "nodemon": "^3.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
